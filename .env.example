AUTH_SECRET=
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_USER=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=

# Optional: base URL used to build absolute links (password reset, email
# verification, Stripe checkout/portal redirects). Falls back to VERCEL_URL,
# then localhost:3000, if unset.
NEXTAUTH_URL=

# Optional: without these, transactional email is skipped and the
# would-be link is logged to the server console instead of sent.
RESEND_API_KEY=

# Optional: without these, billing is disabled and upgrade actions fail
# gracefully with a user-facing "not configured" message.
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
