# react@19.0.0-rc-* is a prerelease build tag that npm's strict peer-dependency
# resolution doesn't recognize as satisfying dependencies' plain ">= 16"/"^19.0"
# ranges (e.g. @heroicons/react, several radix-ui subpackages) — causing
# ERESOLVE failures in any environment without a masking global npm config
# (this was silently working only in dev machines with legacy-peer-deps set
# globally; it fails in a clean CI/deployment environment). Safe here since
# the actual installed react/react-dom versions are pinned exactly in
# package.json, not left to peer-range resolution.
legacy-peer-deps=true
